<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fundo transparente de 108dp (tamanho padrão da Splash API) -->
    <item android:width="108dp" android:height="108dp">
        <shape android:shape="rectangle">
            <color android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- O logo centralizado com bastante respiro para não ser cortado pelo círculo (safe area de 72dp) -->
    <item
        android:gravity="center"
        android:left="22dp"
        android:right="22dp"
        android:top="22dp"
        android:bottom="22dp">
        <bitmap
            android:src="@drawable/splash_logo"
            android:gravity="center"
            android:filter="true" />
    </item>
</layer-list>
